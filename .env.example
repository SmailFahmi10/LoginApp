# --- APP ---
MY_DOMAIN=login.smailfahmi.com

# --- JWT ---
# Generar con: openssl rand -base64 32
JWT_SECRET=cambia-esto-por-un-secreto-fuerte
JWT_EXPIRATION=3600000

# --- CORS ---
# En producción el frontend y la API comparten dominio (Nginx hace de proxy),
# así que CORS no se activa desde el navegador. Se pone igual como medida extra.
CORS_ALLOWED_ORIGINS=https://login.smailfahmi.com

# --- SSO ---
SSO_REDIRECT_URI=https://login.smailfahmi.com/sso/callback
SSO_PROVIDER_URL=https://login.smailfahmi.com/api/auth/sso/provider
